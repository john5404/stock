# FinMind API token (Taiwan institutional investor data)
# Register at https://finmindtrade.com and copy your token here.
FINMIND_TOKEN=

# Discord bot token (for discord_bot.py). Create an app + bot at
# https://discord.com/developers/applications and paste the bot token here.
DISCORD_BOT_TOKEN=

# Optional: restrict/fast-sync slash commands to a single guild (server) id.
# Leave blank to sync globally (can take up to ~1 hour to appear).
DISCORD_GUILD_ID=
